{
  "name": "@destinaph/mobile",
  "private": true,
  "version": "1.0.0",
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "icons:generate": "node scripts/generate-expo-icons.cjs",
    "sync:icon": "node ../../scripts/sync-system-icon.cjs",
    "prebuild:android": "npm run icons:generate && expo prebuild --platform android --clean --no-install",
    "eas:apk": "npx eas-cli build --platform android --profile preview",
    "eas:build:preview": "npx eas-cli build --platform android --profile preview --non-interactive --no-wait",
    "eas:build:production": "npx eas-cli build --platform android --profile production --non-interactive --no-wait",
    "eas:submit:android": "npx eas-cli submit --platform android --latest --non-interactive"
  },
  "dependencies": {
    "@babel/runtime": "^7.25.0",
    "@expo/metro-runtime": "~55.0.9",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native/virtualized-lists": "0.83.4",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@supabase/supabase-js": "^2.49.1",
    "base64-arraybuffer": "^1.0.2",
    "expo": "^55.0.15",
    "expo-audio": "~55.0.13",
    "expo-blur": "~55.0.14",
    "expo-dev-client": "~55.0.27",
    "expo-file-system": "~55.0.16",
    "expo-image-picker": "~55.0.18",
    "expo-linear-gradient": "~55.0.13",
    "expo-location": "~55.1.8",
    "expo-status-bar": "~55.0.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-maps": "1.27.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.2.10",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2"
  }
}
