{
  "expo": {
    "name": "DestinaPH",
    "slug": "destinaph",
    "version": "1.0.0",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B3C5D"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "DestinaPH uses your location to show distances to recommended places and routes on the map."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "DestinaPH uses your photo library so you can set your profile picture.",
          "cameraPermission": "DestinaPH uses the camera so you can take a profile picture."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ph.destinaph.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "DestinaPH uses your location to show distance to destinations and routes on the map.",
        "LSApplicationQueriesSchemes": [
          "maps",
          "comgooglemaps",
          "googlechromes",
          "googlenavigation"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B3C5D"
      },
      "package": "ph.destinaph.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "45a4f3b4-77ee-4783-b96b-d1b3e8331598"
      }
    }
  }
}
